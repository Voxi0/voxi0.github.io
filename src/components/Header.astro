---
// AstroJS native components
import { Image } from "astro:assets";

// Images
import profilePictureAvif from "../images/pfp.avif";
---
<header class="flex flex-nowrap justify-around items-center">
	<!-- Profile -->
	<a href="/" class="flex items-center gap-2 cursor-pointer">
		<Image
			class="w-12 rounded-full"
			loading="eager"
			decoding="async"
			src={profilePictureAvif}
			alt="My profile"
			format="avif"
			quality={50}
		/>
		<div class="prose">
			<h2>Voxi0</h2>
		</div>
	</a>

	<!-- Random art - "Borrowed" from `https://soph.systems/` :P -->
	<div class="prose">
		<h2>ᓚᘏᗢ</h2>
	</div>

	<!-- Navigation bar -->
	<nav>
		<a href="/" target="_self">home</a>
		<a href="/about" target="_self">about</a>
	</nav>
</header>
