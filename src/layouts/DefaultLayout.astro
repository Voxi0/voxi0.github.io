---
// Components
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

// Canonical URL - Helps search engines to index the correct URL and avoid duplicate content
const canonicalURL = new URL(Astro.url.pathname, Astro.site);

// Props
const { title, description } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
	<head>
		<!-- Global metadata -->
		<meta charset="utf-8">
		<meta name="viewport" content="width=device-width,initial-scale=1">
		<meta name="generator" content={Astro.generator}>
		<link rel="sitemap" href="/sitemap-index.xml"/>
		<link rel="icon" type="image/svg+xml" href="/favicon.svg"/>
		<link rel="alternate" type="application/rss+xml" title={title} href={new URL("rss.xml", Astro.site)}/>

		<!-- Preload fonts for performance -->
		<link rel="preload" href="/fonts/Iosevka/IosevkaNerdFont-Regular.ttf" as="font" type="font/truetype" crossorigin="anonymous">

		<!-- Canonical URL - Helps search engines to index the correct URL and avoid duplicate content -->
		<link rel="canonical" href={canonicalURL}>

		<!-- Website title and description -->
		<meta name="title" content={title}>
		<meta name="description" content={description}>
		<title>{title}</title>
	</head>
	<body>
		<Header/>
		<hr>

		<!-- Our code inserted here -->
		<slot/>

		<Footer/>
	</body>
</html>
